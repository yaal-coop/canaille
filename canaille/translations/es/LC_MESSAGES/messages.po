msgstr ""
"Tipos de concesión que el cliente puede utilizar en el punto final del vale."

#: canaille/oidc/endpoints/forms.py:199
#: canaille/templates/oidc/token_view.html:70
msgid "Scope"
msgstr "Ámbito"

#: canaille/oidc/endpoints/forms.py:203
msgid "Kind of information that the client can request about users."
msgstr ""
"Familia de información que el cliente puede solicitar acerca de usuarios."

#: canaille/oidc/endpoints/forms.py:207
msgid "Response types"
msgstr "Tipos de respuesta"

#: canaille/oidc/endpoints/forms.py:212
msgid "Response types that the client can use at the authorization endpoint."
msgstr ""
"Tipos de respuesta que el cliente puede utilizar en el punto final de "
"autorización."

#: canaille/oidc/endpoints/forms.py:217
msgid "Token endpoint authentication method"
msgstr "Método de autenticación para el punto final del vale"

#: canaille/oidc/endpoints/forms.py:228
msgid "Authentication method that the client will use at the token endpoint."
msgstr ""
"Método de autenticación que el cliente utilizará en el punto final del vale."

#: canaille/oidc/endpoints/forms.py:233
msgid "Token audiences"
msgstr "Audiencias del vale"

#: canaille/oidc/endpoints/forms.py:239
msgid ""
"The other clients that are intended to use the tokens emitted by this client."
msgstr ""
"Los otros clientes que son intentados para utilizar los vales emitidos por "
"este cliente."

#: canaille/oidc/endpoints/forms.py:244
msgid "Logo URI"
msgstr "URI del logo"

#: canaille/oidc/endpoints/forms.py:250
msgid "An URL for the logo of this client."
msgstr "Una URL para el logotipo de este cliente."

#: canaille/oidc/endpoints/forms.py:254
msgid "Terms of service URI"
msgstr "URI de los términos de servicio"

#: canaille/oidc/endpoints/forms.py:260
msgid "URL to the terms of service of the client."
msgstr "URL para los términos de servicio del cliente."

#: canaille/oidc/endpoints/forms.py:264
msgid "Policy URI"
msgstr "Directiva URI"

#: canaille/oidc/endpoints/forms.py:270
msgid "URL to the privacy policy of the client."
msgstr "URL para la directiva de privacidad del cliente."

#: canaille/oidc/endpoints/forms.py:274
msgid "Software ID"
msgstr "ID del software"

#: canaille/oidc/endpoints/forms.py:278
msgid ""
"Unique identifier for this client, that should be stable in time and common "
"for all identity providers."
msgstr ""
"Identificador único para este cliente, que sería estable en tiempo y usual "
"para todos los proveedores de identidad."

#: canaille/oidc/endpoints/forms.py:283
msgid "Software Version"
msgstr "Versión del software"

#: canaille/oidc/endpoints/forms.py:286
msgid "The version of the client."
msgstr "La versión del cliente."

#: canaille/oidc/endpoints/forms.py:290
msgid "JSON Web Keys"
msgstr "Claves Web de JSON"

#: canaille/oidc/endpoints/forms.py:293
msgid "The public JSON Web Keys of the client."
msgstr "Las claves web JSON públicas del cliente."

#: canaille/oidc/endpoints/forms.py:297
msgid "JSON Web Keys URI"
msgstr "URI de Claves Web JSON"

#: canaille/oidc/endpoints/forms.py:303
msgid "The URI that points to the public JSON Web Keys of the client."
msgstr "La URL que apunta a las Claves Web JSON públicas del cliente."

#: canaille/oidc/endpoints/forms.py:307
msgid "Token endpoint authentication signing algorithm"
msgstr "Algoritmo de firma de autenticación en vale en punto final"

#: canaille/oidc/endpoints/forms.py:313
msgid ""
"JWS algorithm that must be used for signing the JWT used to authenticate the "
"client at the token endpoint for the private_key_jwt and client_secret_jwt "
"authentication methods."
msgstr ""
"Algoritmo JWS que debe ser utilizado para firmar el JWT utilizado para "
"autenticar el cliente en el punto final del vale para los métodos de "
"autenticación private_key_jwt y client_secret_jwt."

#: canaille/oidc/endpoints/forms.py:318
msgid "Sector identifier URI"
msgstr "URI identificador de sector"

#: canaille/oidc/endpoints/forms.py:325
msgid ""
"URL using the https scheme to be used in calculating pseudonymous "
"identifiers by the OP. The URL references a file with a single JSON array of "
"redirect_uri values."
msgstr ""
"URI utilizando el esquema https para ser utilizado en cálculo "
"identificadores de seudónimo por el OP. La URL referencia un archivo con un "
"vector JSON de valores redirect_uri."

#: canaille/oidc/endpoints/forms.py:330
msgid "Subject type"
msgstr "Tipo de asunto"

#: canaille/oidc/endpoints/forms.py:338
msgid ""
"Subject identifier type requested for responses to this client. Valid types "
"include pairwise and public."
msgstr ""
"Se ha solicitando un tipo de identificador del sujeto para respuestas a este "
"cliente. Los tipos válidos incluyen por pares y público."

#: canaille/oidc/endpoints/forms.py:343
msgid "Application type"
msgstr "Tipo de aplicación"

#: canaille/oidc/endpoints/forms.py:351
msgid ""
"Kind of the application. Web clients must use https redirect URIs. Native "
"clients can use custom URI schemes or http loopback URLs."
msgstr ""
"Familia de la aplicación. El cliente de web debe utilizar las URI de "
"redirección https. Los clientes nativos pueden utilizar esquemas URI "
"personales o las URL de bucle http."

#: canaille/oidc/endpoints/forms.py:356
msgid "ID Token signed response algorithm"
msgstr "Vale del ID firmó algoritmo de respuesta"

#: canaille/oidc/endpoints/forms.py:363
msgid ""
"JWS algorithm required for signing the ID Token issued to this client. The "
"value 'none' must not be used unless the client uses only response types "
"that return no ID Token from the authorization endpoint."
msgstr ""
"Se requiere el algoritmo JWS para firmar el vale de identificación de "
"incidencia a este cliente. El valor 'none' no debe utilizarse a menos que el "
"cliente utilice únicamente tipos de respuesta que no devuelvan ningún vale "
"de identificación desde el punto final de autorización."

#: canaille/oidc/endpoints/forms.py:368
msgid "UserInfo signed response algorithm"
msgstr "Algoritmo de respuesta firmada de UserInfo"

#: canaille/oidc/endpoints/forms.py:372
msgid ""
"JWS algorithm required for signing UserInfo responses. If specified, the "
"response will be JWT serialized and signed using JWS. If omitted, the "
"UserInfo response will return the claims as a UTF-8 encoded JSON object "
"using the application/json content-type."
msgstr ""
"Se requiere el algoritmo JWS para firmar las respuestas UserInfo. Si se "
"especifica, la respuesta se serializará en formato JWT y se firmará mediante "
"JWS. Si se omite, la respuesta UserInfo devolverá las declaraciones como un "
"objeto JSON codificado en UTF-8 utilizando el tipo de contenido application/"
"json."

#: canaille/oidc/endpoints/forms.py:377
msgid "Default maximum authentication age"
msgstr "Espera máxima de autenticación predeterminada"

#: canaille/oidc/endpoints/forms.py:381
msgid ""
"Default maximum authentication age in seconds. Specifies that the end-user "
"must be actively authenticated if the end-user was authenticated longer ago "
"than the specified number of seconds. The max_age request parameter "
"overrides this default value."
msgstr ""
"Espera máxima de autenticación predeterminada en segundos. Indica que el "
"usuario final debe estar autenticado activamente si su autenticación "
"anterior superó el número de segundos especificado. El parámetro de "
"solicitud max_age anula este valor predeterminado."

#: canaille/oidc/endpoints/forms.py:386
msgid "Require auth_time claim"
msgstr "Requerir reclamación auth_time"

#: canaille/oidc/endpoints/forms.py:389
msgid ""
"Boolean value specifying whether the auth_time claim in the ID Token is "
"required. It is required when the value is true."
msgstr ""
"Valor booleano que especifica si la reclamación auth_time en el vale de ID "
"es obligatoria. Es obligatoria cuando el valor es verdadero."

#: canaille/oidc/endpoints/forms.py:395
msgid "Default ACR values"
msgstr "Valores ACR por defecto"

#: canaille/oidc/endpoints/forms.py:402
msgid ""
"Default requested Authentication Context Class Reference values. Array of "
"strings that specifies the default acr values that the OP is being requested "
"to use for processing requests from this client, with the values appearing "
"in order of preference."
msgstr ""
"Valores de referencia de clase contextual de autenticación por defecto. "
"Matriz de cadenas que especifica los valores ACR predeterminados que se le "
"solicita al OP que utilice para procesar las solicitudes de este cliente, "
"con los valores apareciendo en orden de preferencia."

#: canaille/oidc/endpoints/forms.py:407
msgid "Initiate login URI"
msgstr "Iniciar URI de acceso"

#: canaille/oidc/endpoints/forms.py:414
msgid ""
"URI using the https scheme that a third party can use to initiate a login by "
"the RP. The URI must accept requests via both GET and POST."
msgstr ""
"URI utilizando esquema https que una parte de terceros utilice para "
"inicializar un acceso por el RP. La URI debe aceptar solicitudes por medio "
"de GET y POST."

#: canaille/oidc/endpoints/forms.py:419
msgid "Request object signing algorithm"
msgstr "Algoritmo firmante de objeto de solicitud"

#: canaille/oidc/endpoints/forms.py:425
msgid ""
"JWS algorithm that must be used for signing request objects sent to the OP. "
"All request objects from this client must be rejected if not signed with "
"this algorithm. This algorithm must be used both when the request object is "
"passed by value (using the request parameter) and when it is passed by "
"reference (using the request_uri parameter)."
msgstr ""
"El algoritmo JWS que debe ser utilizado para firmar objetos de solicitud "
"enviados al OP. Todos los objetos de solicitud de este cliente deben ser "
"rechazados si no están firmados con este algoritmo. Este algoritmo debe ser "
"utilizado tanto cuando el objeto de solicitud está concedido por valor "
"(utilizando el parámetro de solicitud) y cuando se transmite por referencia "
"(utilizando el parámetro request_uri)."

#: canaille/oidc/endpoints/forms.py:431
msgid "Request URIs"
msgstr "Solicitud de las URI"

#: canaille/oidc/endpoints/forms.py:443
msgid ""
"Array of request_uri values that are pre-registered by the RP for use at the "
"OP. These URLs must use the https scheme unless the target request object is "
"signed in a way that is verifiable by the OP. Servers may cache the contents "
"of the files referenced by these URIs."
msgstr ""

#: canaille/oidc/endpoints/forms.py:448
msgid "Require signed request object"
msgstr "Requiere objeto de solicitud firmado"

#: canaille/oidc/endpoints/forms.py:451
msgid ""
"Indicates whether authorization request needs to be protected as a request "
"object and provided through either request or request_uri parameter."
msgstr ""
"Indica si la solicitud de autorización necesita ser protegida como un objeto "
"de solicitud y proporcionado a través de cualquier solicitud o parámetro "
"request_uri."

#: canaille/oidc/endpoints/oauth.py:548
msgid "You have been disconnected."
msgstr "Has sido desconectado."

#: canaille/oidc/endpoints/oauth.py:566
msgid "You have not been disconnected."
msgstr "No has sido desconectado."

