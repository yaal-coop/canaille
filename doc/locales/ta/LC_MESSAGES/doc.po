#: ../../canaille/core/configuration.py:docstring of
#: canaille.core.configuration.ACLSettings:1 9e1d58276266410991b531ee31d75f6b
msgid "Access Control List settings. Belong in the ``CANAILLE.ACL`` namespace."
msgstr ""
"கட்டுப்பாட்டு பட்டியல் அமைப்புகளை அணுகவும். ``CANAILLE.ACL`` பெயர்வெளியில் உள்ளது."

#: ../../canaille/core/configuration.py:docstring of
#: canaille.core.configuration.ACLSettings:3 f05ca0ae600e4048b230129cb92bc883
msgid ""
"You can define access controls that define what users can do on canaille. An "
"access control consists in a :attr:`FILTER` to match users, a list "
"of :attr:`PERMISSIONS` matched users will be able to perform, and fields "
"users will be able to :attr:`READ` and :attr:`WRITE`. Users matching several "
"filters will cumulate permissions."
msgstr ""
"canaille இல் பயனர்கள் என்ன செய்ய முடியும் என்பதை வரையறுக்கும் அணுகல் கட்டுப்பாடுகளை நீங்கள் "
"வரையறுக்கலாம். ஒரு அணுகல் கட்டுப்பாடு பயனர்களுடன் பொருந்துவதற்கு:attr:`FILTER` இல் "
"உள்ளது, :attr:`PERMISSIONS` பொருந்திய பயனர்களின் பட்டியல் செயல்படும், மேலும் பயனர்கள் "
":attr:`READ` மற்றும் :attr:`WRITE` ஆகியவற்றைக் களமிறக்க முடியும். பல வடிப்பான்களைப் "
"பொருத்தும் பயனர்கள் அனுமதிகளைக் குவிப்பார்கள்."

#: ../../docstring of canaille.core.configuration.ACLSettings.FILTER:1
#: 5e9b6a99d7fb407e92fb300660538172
msgid ":attr:`FILTER` can be:"
msgstr ":attr:`FILTER` ஆக இருக்கலாம்:"

#: ../../docstring of canaille.core.configuration.ACLSettings.FILTER:3
#: 76e78405a9bd4c21bbebd9348325b292
msgid ""
":py:data:`None`, in which case all the users will match this access control"
msgstr ""
":py:data:`இல்லை`, இந்த அணுகல் கட்டுப்பாட்டுடன் அனைத்து பயனர்களும் பொருந்துவார்கள்"

#: ../../docstring of canaille.core.configuration.ACLSettings.FILTER:4
#: 5e38e30ebf3d4d10ad821424f05fc3e8
msgid ""
"a mapping where keys are user attributes name and the values those user "
"attribute values. All the values must be matched for the user to be part of "
"the access control."
msgstr ""
"விசைகள் பயனர் பண்புக்கூறுகளின் பெயர் மற்றும் அந்த பயனர் பண்புக்கூறு மதிப்புகள் ஆகியவை "
"மேப்பிங். அணுகல் கட்டுப்பாட்டின் ஒரு பகுதியாக பயனர் இருக்க அனைத்து மதிப்புகளும் பொருந்த "
"வேண்டும்."

#: ../../docstring of canaille.core.configuration.ACLSettings.FILTER:7
#: deaba7a99763469da7726e75144f9104
msgid ""
"a list of those mappings. If a user values match at least one mapping, then "
"the user will be part of the access control"
msgstr ""
"அந்த வரைபடங்களின் பட்டியல். ஒரு பயனர் மதிப்புகள் குறைந்தது ஒரு மேப்பிங்கில் பொருந்தினால், "
"பயனர் அணுகல் கட்டுப்பாட்டின் ஒரு பகுதியாக இருப்பார்"

#: ../../docstring of canaille.core.configuration.ACLSettings.FILTER:10
#: 26e4f57af9fd46789ed021c299fa7424
msgid "Here are some examples:"
msgstr "இதோ சில உதாரணங்கள்:"

#: ../../docstring of canaille.core.configuration.ACLSettings.PERMISSIONS:1
#: edce6ac4118f4fbba9c0990d7277c1d9
msgid ""
"A list of :class:`Permission` users in the access control will be able to "
"manage."
msgstr ""
"அணுகல் கட்டுப்பாட்டில் உள்ள :class:`Permission` பயனர்களின் பட்டியலை நிர்வகிக்க முடியும்."

#: ../../docstring of canaille.core.configuration.ACLSettings.PERMISSIONS:4
#: 155800aa33f94a3a9aa519c2339e528d
msgid ""
"By default, users can edit their own profile, use OpenID Connect, and manage "
"their own groups."
msgstr ""
"இயல்பாக, பயனர்கள் தங்கள் சொந்த சுயவிவரத்தைத் திருத்தலாம், OpenID இணைப்பைப் பயன்படுத்தலாம் "
"மற்றும் தங்கள் சொந்த குழுக்களை நிர்வகிக்கலாம்."

#: ../../docstring of canaille.core.configuration.ACLSettings.READ:1
#: a8b985d6564c4133885d925257151f2c
msgid ""
"A list of :class:`~canaille.core.models.User` attributes that users in the "
"ACL will be able to read."
msgstr ""
"ACL இல் உள்ள பயனர்கள் படிக்கக்கூடிய :class:`~canaille.core.models.User` "
"பண்புக்கூறுகளின் பட்டியல்."

#: ../../docstring of canaille.core.configuration.ACLSettings.WRITE:1
#: ac58de17369c4365a41679cb7e6a1e81
msgid ""
"A list of :class:`~canaille.core.models.User` attributes that users in the "
"ACL will be able to edit."
msgstr ""
"ACL இல் உள்ள பயனர்கள் திருத்தக்கூடிய :class:`~canaille.core.models.User` "
"பண்புக்கூறுகளின் பட்டியல்."

#: ../../canaille/core/configuration.py:docstring of
#: canaille.core.configuration.Permission:1 45331c41c07544f2bdae8c63d1e32246
msgid "The permissions that can be assigned to users."
msgstr "பயனர்களுக்கு ஒதுக்கக்கூடிய அனுமதிகள்."

#: ../../canaille/core/configuration.py:docstring of
#: canaille.core.configuration.Permission:3 45c9b452182f4f8d89effdf53f02b56b
msgid ""
"The permissions are intended to be used in :attr:`ACLSettings "
"<canaille.core.configuration.ACLSettings.PERMISSIONS>`."
msgstr ""
"அனுமதிகள் :attr:`ACLSettings "
"<canaille.core.configuration.ACLSettings.PERMISSIONS>` இல் பயன்படுத்தப்பட வேண்டும்."

#: ../../docstring of canaille.core.configuration.Permission.DELETE_ACCOUNT:1
#: c08e2455d71f42889ccc855a5a05427f
msgid "Allows users to delete their account."
msgstr "பயனர்கள் தங்கள் கணக்கை நீக்க அனுமதிக்கிறது."

#: ../../docstring of canaille.core.configuration.Permission.DELETE_ACCOUNT:3
#: 436036d2fbb74b6ca5a3c19c1d0bfcef
msgid ""
"If used with :attr:`~canaille.core.configuration.Permission.MANAGE_USERS`, "
"users can delete any account."
msgstr ""
":attr:`~canaille.core.configuration.Permission.MANAGE_USERS` உடன் "
"பயன்படுத்தினால், பயனர்கள் எந்தக் கணக்கையும் நீக்கலாம்."

#: ../../docstring of canaille.core.configuration.Permission.EDIT_SELF:1
#: 5baae97eea72457586f563069b5db7e3
msgid "Allows users to edit their own profile."
msgstr "பயனர்கள் தங்கள் சொந்த சுயவிவரத்தைத் திருத்த அனுமதிக்கிறது."

#: ../../docstring of
#: canaille.core.configuration.Permission.IMPERSONATE_USERS:1
#: 4f39f7061a494a69a64cc0d944f4a2b3
msgid "Allows users to take the identity of another user."
msgstr "மற்றொரு பயனரின் அடையாளத்தை எடுக்க பயனர்களை அனுமதிக்கிறது."

#: ../../docstring of
#: canaille.core.configuration.Permission.MANAGE_ALL_GROUPS:1
#: 94ab9a196d1f47c18b7c35057ff611c4
msgid "Allows edition and creation of all groups (administrator permission)."
msgstr ""
"அனைத்து குழுக்களின் பதிப்பு மற்றும் உருவாக்கத்தை அனுமதிக்கிறது (நிர்வாகி அனுமதி)."

#: ../../docstring of canaille.core.configuration.Permission.MANAGE_OIDC:1
#: ffa9015858084650bcd5fb9d185f3564
msgid "Allows OpenID Connect client managements."
msgstr "OpenID இணை கிளையன்ட் நிர்வாகத்தை அனுமதிக்கவும்."

#: ../../docstring of
#: canaille.core.configuration.Permission.MANAGE_OWN_GROUPS:1
#: 656d45342f094ca4a4e62f0a06e89fa1
msgid "Allows users to create their own groups and manage groups they own."
msgstr ""
"பயனர்கள் தங்கள் சொந்த குழுக்களை உருவாக்க மற்றும் அவர்களுக்கு சொந்தமான குழுக்களை நிர்வகிக்க "
"அனுமதிக்கிறது."

#: ../../docstring of canaille.core.configuration.Permission.MANAGE_USERS:1
#: e6b977fc1bef4d3399e4f0eaa59058ed
msgid "Allows other users management."
msgstr "பிற பயனர் நிர்வாகத்தை அனுமதிக்கிறது."

#: ../../docstring of canaille.core.configuration.Permission.USE_OIDC:1
#: 8f67c6afcd944b1a99fd327c2db8ceff
msgid "Allows OpenID Connect authentication."
msgstr "OpenID இணைப்பு அங்கீகாரத்தை அனுமதிக்கிறது."

#: ../../canaille/oidc/configuration.py:docstring of
#: canaille.oidc.configuration.OIDCSettings:1 b9474d67c06d4556bfea2ed499284ee8
msgid "OpenID Connect settings."
msgstr "OpenID இணைப்பு அமைப்புகள்."

#: ../../canaille/oidc/configuration.py:docstring of
#: canaille.oidc.configuration.OIDCSettings:3 57648e373354464c9c6981ec82c691b4
msgid "Belong in the ``CANAILLE_OIDC`` namespace."
msgstr "``CANAILLE_OIDC`` பெயர்வெளியில் உள்ளது."

#: ../../docstring of canaille.oidc.configuration.OIDCSettings.ACTIVE_JWKS:1
#: 8d0617a884a8410d84ac60a959f8c585
msgid "The active JSON Web Keys Set."
msgstr "செயலில் உள்ள சாதொபொகு இணைய விசைகள் தொகுப்பு."

#: ../../docstring of canaille.oidc.configuration.OIDCSettings.ACTIVE_JWKS:3
#: badabade3e9c4cceb82d82bc146240b4
msgid ""
"Those keys are used to sign and verify JWTs. The keys can be in the form of "
"JWK dict or raw keys."
msgstr ""
"JWT களில் கையொப்பமிடவும் சரிபார்க்கவும் அந்த விசைகள் பயன்படுத்தப்படுகின்றன. விசைகள் JWK "
"டிக்ட் அல்லது ரா கீகள் வடிவத்தில் இருக்கலாம்."

#: ../../docstring of
#: canaille.oidc.configuration.OIDCSettings.DYNAMIC_CLIENT_REGISTRATION_OPEN:1
#: 0731e74cd1704a8a9702b7cfbe582552
msgid ""
"Whether a token is needed for the RFC7591 dynamical client registration."
msgstr "RFC7591 டைனமிகல் கிளையன்ட் பதிவுக்கு கிள்ளாக்கு தேவையா."

#: ../../docstring of
#: canaille.oidc.configuration.OIDCSettings.DYNAMIC_CLIENT_REGISTRATION_OPEN:3
#: f8946eeb57114783aa2409b5b1c61c4c
msgid ""
"If :py:data:`True`, no token is needed to register a client. "
"If :py:data:`False`, dynamical client registration requires a valid JWT "
"token generated by the ``canaille oidc registration generate-token`` command."
msgstr ""
":py:data:`True` எனில், கிளையண்டை பதிவு செய்ய கிள்ளாக்கு தேவையில்லை. "
":py:data:`False` எனில், டைனமிகல் கிளையன்ட் பதிவுக்கு ``canaille oidc registration "
"generate-token`` கட்டளையால் உருவாக்கப்பட்ட சரியான JWT கிள்ளாக்கு தேவைப்படுகிறது."

#: ../../docstring of canaille.oidc.configuration.OIDCSettings.ENABLE_OIDC:1
#: 5eabcbd4f2cf4b7fb5e3b340319f9892
msgid ""
"Whether the Single Sign-On feature and the OpenID Connect API is enabled."
msgstr "ஒற்றை உள்நுழைவு நற்பொருத்தம் மற்றும் OpenID இணை பநிஇ இயக்கப்பட்டுள்ளதா."

#: ../../docstring of canaille.oidc.configuration.OIDCSettings.INACTIVE_JWKS:1
#: 065c15c649ea4af7b6c58e0224b74d47
msgid "The inactive JSON Web Keys Set."
msgstr "செயலற்ற சாதொபொகு இணைய விசைகள் தொகுப்பு."

#: ../../docstring of canaille.oidc.configuration.OIDCSettings.INACTIVE_JWKS:3
#: 1f0b9e8412b34d1fb7af9a248f43a261
msgid ""
"Those keys are only used to verify JWTs. The keys can be in the form of JWK "
"dict or raw keys."
msgstr ""
"அந்த விசைகள் JWTகளை சரிபார்க்க மட்டுமே பயன்படுத்தப்படும். விசைகள் JWK டிக்ட் அல்லது ரா கீகள் "
"வடிவத்தில் இருக்கலாம்."

#: ../../docstring of canaille.oidc.configuration.OIDCSettings.REQUIRE_NONCE:1
#: 253d726f287f4ca48c7fe71216c0e18c
msgid "Force the nonce exchange during the authentication flows."
msgstr "அங்கீகரிப்பு ஓட்டங்களின் போது, பரிமாற்றத்தை கட்டாயப்படுத்தவும்."

#: ../../docstring of canaille.oidc.configuration.OIDCSettings.REQUIRE_NONCE:3
#: aa7e5c6d99d14a379c68567b2097ed58
msgid "This adds security but may not be supported by all clients."
msgstr ""
"இது பாதுகாப்பைச் சேர்க்கிறது ஆனால் எல்லா வாடிக்கையாளர்களாலும் ஆதரிக்கப்படாமல் போகலாம்."

#: ../../docstring of
#: canaille.oidc.configuration.OIDCSettings.TRUSTED_DOMAINS:1
#: 0a8448acd5024798807534b8cf980a86
msgid "Trusted domains for automatic client trust."
msgstr "தானியங்கி வாடிக்கையாளர் நம்பிக்கைக்கான நம்பகமான டொமைன்கள்."

#: ../../docstring of
#: canaille.oidc.configuration.OIDCSettings.TRUSTED_DOMAINS:3
#: 009faac292cf4aa2b5052068ce5b8295
msgid ""
"Clients with a :attr:`~canaille.oidc.basemodels.Client.client_uri` matching "
"these domains will be automatically considered as trusted and will not "
"display the consent page to users. This is particularly useful for "
"development environments."
msgstr ""
"இந்த டொமைன்களுடன் பொருந்தக்கூடிய "
":attr:`~canaille.oidc.basemodels.Client.client_uri` உள்ள வாடிக்கையாளர்கள் தானாக "
"நம்பகமானவர்களாகக் கருதப்படுவார்கள் மேலும் பயனர்களுக்கு ஒப்புதல் பக்கத்தைக் காட்ட மாட்டார்கள். வளர்ச்சி "
"சூழல்களுக்கு இது மிகவும் பயனுள்ளதாக இருக்கும்."

