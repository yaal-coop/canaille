msgstr "10 நிமிடங்களுக்கு ``PT10M``"

#: ../../docstring of canaille.core.configuration.CoreSettings.OTP_LIFETIME:9
#: 93f4b9a4eead4917b8f18d32ab85e1d3
msgid "``PT5M`` for 5 minutes"
msgstr "5 நிமிடங்களுக்கு ``PT5M``"

#: ../../docstring of canaille.core.configuration.CoreSettings.OTP_LIFETIME:10
#: 6625255bb46948d1b78bc6656b6adaa0
